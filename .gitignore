# macOS metadata
.DS_Store
**/.DS_Store

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Local env / secrets
.env
.env.local
*.env

# OAuth tokens + service account keys — NEVER commit these
config.json
youtube_token_*.json
youtube_client_secrets.json
video-studio-*.json

# Render output (large mp4s — keep out of git)
MZ_Output/
TMF_Output/
BSG_Output/

# Local work artifacts (auto_trigger_*.json IS tracked by the workflow,
# don't gitignore — TMF/BSG already commit these per-run)
*_work/

# Temp render folders (scene-by-scene build artifacts)
bsg_temp_*/
tmf_temp_*/
mz_temp_*/

# Local voice files
bsg_voices/
tmf_voices/
mz_voices/

# Log files
*.log
watcher.log
watcher_error.log

# Local watcher / launch agent files
start.sh
*.plist
com.*.autopost-watcher.plist
